# Local: copy to .env.local (never commit). Same values as Vercel → Environment Variables.

SITE_PASSWORD=fucktaxpro2026

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_or_secret_key

# OpenAI — required for invoice extraction + optional chat assistant
OPENAI_API_KEY=

# Models (default gpt-4o-mini = higher rate limits, lower cost). Use gpt-4o only if you raised TPM.
OPENAI_ASSISTANT_MODEL=gpt-4o-mini
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
# Pause between PDF extractions in ms (reduces TPM bursts on upload). Default 1500.
# OPENAI_THROTTLE_MS=1500

# If you still hit rate limits: platform.openai.com → Settings → Organization → Limits
# Add payment method + request higher TPM for your model, or keep gpt-4o-mini.

# Web search for unknown vendors (tavily.com free tier, or serper.dev)
TAVILY_API_KEY=

# ELSTER export (Steuernummer without slashes — default from company: 202/110/00377)
ELSTER_STEUERNUMMER=20211000377

# Run supabase/filing-todos.sql after review-chat.sql for chat todos
# npm run inspect:uploads | inspect:chats
# Run supabase/chat-analytics.sql once for full chat logging
